# Database - SQLite (default for local dev, no server needed)
DATABASE_URL="file:./dev.db"

# To use PostgreSQL instead, comment out SQLite above and uncomment:
# DATABASE_URL="postgresql://user:password@localhost:5432/procedure_builder"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-secret-in-production"

# File storage (local filesystem for dev)
UPLOAD_DIR="./uploads"
NEXT_PUBLIC_UPLOAD_URL="/uploads"

# Optional: Set to "production" for prod
NODE_ENV="development"
